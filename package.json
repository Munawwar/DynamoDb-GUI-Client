{
  "name": "dynamodb-gui-client",
  "desktopName": "com.dynamodb.guiclient",
  "version": "3.5.7",
  "description": "DynamoDb-GUI-Client",
  "author": {
    "name": "Misak Poghosyan",
    "url": "https://github.com/Arattian"
  },
  "scripts": {
    "build": "node --openssl-legacy-provider ./node_modules/@vue/cli-service/bin/vue-cli-service.js build",
    "lint": "node --openssl-legacy-provider ./node_modules/@vue/cli-service/bin/vue-cli-service.js lint",
    "package": "npm run build && electron-builder",
    "start": "npm run build && env ELECTRON_OZONE_PLATFORM_HINT=x11 LIBGL_ALWAYS_SOFTWARE=1 electron . --no-sandbox --disable-gpu-sandbox",
    "start:sandbox": "npm run build && electron .",
    "test:unit": "node --openssl-legacy-provider ./node_modules/@vue/cli-service/bin/vue-cli-service.js test:unit --coverage"
  },
  "dependencies": {
    "aws-sdk": "^2.1286.0",
    "element-ui": "^2.7.0",
    "vue": "^2.6.10",
    "vue-awesome": "^3.5.1",
    "vue-class-component": "^7.0.2",
    "vue-json-editor": "1.2.3",
    "vue-property-decorator": "^8.1.0",
    "vue-resize-split-pane": "^0.1.5",
    "vuex": "^3.1.0",
    "vuex-class": "^0.3.2"
  },
  "devDependencies": {
    "@types/jest": "^24.0.11",
    "@types/node": "^10.17.60",
    "@vue/cli-plugin-babel": "3.5.3",
    "@vue/cli-plugin-typescript": "3.5.3",
    "@vue/cli-plugin-unit-jest": "3.5.3",
    "@vue/cli-service": "3.5.3",
    "@vue/test-utils": "^1.0.0-beta.29",
    "babel-core": "^7.0.0-bridge.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "element-theme-dark": "^1.0.3",
    "pug": "^2.0.3",
    "pug-plain-loader": "^1.0.0",
    "stylus": "^0.54.5",
    "stylus-loader": "^3.0.2",
    "ts-jest": "^24.0.1",
    "typescript": "^3.4.1",
    "vue-cli-plugin-element": "^1.0.1",
    "vue-template-compiler": "^2.6.10"
  },
  "keywords": [
    "element-ui",
    "npm",
    "package",
    "dark",
    "theme",
    "dynamodb",
    "gui"
  ],
  "license": "MIT",
  "main": "electron/main.js",
  "build": {
    "appId": "com.dynamodb.guiclient",
    "productName": "DynamoDbGUI",
    "asar": true,
    "files": [
      "build/icons/**/*",
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "linux": {
      "category": "Development",
      "icon": "build/icons",
      "syncDesktopName": true,
      "target": [
        "AppImage"
      ]
    }
  },
  "repository": "Arattian/DynamoDb-GUI-Client",
  "overrides": {
    "deasync": "0.1.31"
  }
}
